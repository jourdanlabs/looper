# ── Jira (functional v1 — live initiative source) ─────────────────────────────
# Create API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_SITE=https://your-org.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=

# Project key OR custom JQL (JQL wins if both set)
JIRA_PROJECT_KEY=PROJ
# Backends (defaults: INTAKE, GOV)
# JIRA_INTAKE_PROJECT_KEY=INTAKE
# JIRA_PPO_PROJECT_KEY=GOV
# JIRA_JQL=project = PROJ AND type = Epic AND statusCategory != Done ORDER BY updated DESC

# Without the four required vars above, the app runs in STUB mode:
# in-memory INTAKE/GOV — fully functional for demo, zero Atlassian dependency.

# Push behavior (default: on)
# JIRA_PUSH_COMMENTS=false
# JIRA_PUSH_PRIORITY=false

# ── Confluence (optional — publish portfolio readout) ─────────────────────────
# Defaults to JIRA_SITE / JIRA_EMAIL / JIRA_API_TOKEN when omitted
CONFLUENCE_SPACE_KEY=PROJ
CONFLUENCE_PARENT_PAGE_ID=
CONFLUENCE_PUBLISH_PAGE_ID=
