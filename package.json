{
  "name": "looper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "LOOPER — a deterministic, auditable product-prioritization operating layer: intake → dedup → score (RICE + NPV) → tier → allocate → ledger. Strategy becomes rank, rank becomes commitment, and every decision carries a receipt.",
  "author": "JourdanLabs",
  "license": "Apache-2.0",
  "bin": {
    "looper": "./cli.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "bundle": "next build && node scripts/bundle.mjs",
    "start": "node server.mjs",
    "test": "node --test test/*.test.mjs lib/**/*.test.mjs",
    "prioritize": "node cli.mjs prioritize",
    "brief": "node cli.mjs brief",
    "verify": "node cli.mjs verify"
  },
  "dependencies": {
    "next": "16.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
